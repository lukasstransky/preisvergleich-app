rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User data: shopping lists, favorites, settings
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Premium entitlement: readable by its owner, but only writable by the
    // server (RevenueCat webhook via Admin SDK, which bypasses these rules).
    // Keeping it in a separate top-level collection means the users/** wildcard
    // above cannot grant clients write access to their own entitlement.
    match /entitlements/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Monetization config: read-only for clients, server-managed.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Price alerts: strict for new alerts (userId required), lenient for legacy (no userId)
    match /price_alerts/{alertId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || resource.data.userId == null);

      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || resource.data.userId == null);
    }
  }
}
